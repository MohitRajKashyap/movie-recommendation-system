# ─────────────────────────────────────────────────────────
#  Movie Recommendation System — Environment Variables
# ─────────────────────────────────────────────────────────
#
#  Copy this file to .env and fill in your values.
#  Get your TMDB API key at: https://www.themoviedb.org/settings/api
#
# TMDB API Key (required for posters, ratings, overviews)
TMDB_API_KEY=your_tmdb_api_key_here

# Optional: Set to "true" to use offline/cached data only
OFFLINE_MODE=false
